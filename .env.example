# STT Server Configuration
# Copy this file to .env and adjust values as needed.
# All variables are prefixed with STT_.

# Backend: "mock" (no GPU) or "qwen3" (requires CUDA)
STT_BACKEND=qwen3

# Server bind address
STT_HOST=0.0.0.0
STT_PORT=8000

# Queue sizes
STT_IN_QUEUE_SIZE=200
STT_OUT_QUEUE_SIZE=50

# File upload limit (bytes, default 100MB)
STT_MAX_UPLOAD_BYTES=104857600

# vLLM backend config
STT_VLLM_MODEL=Qwen/Qwen3-ASR-1.7B
STT_VLLM_GPU_MEMORY=0.7
STT_VLLM_MAX_TOKENS=512
STT_VLLM_MAX_INFERENCE_BATCH_SIZE=32

# VAD config
STT_VAD_THRESHOLD=300
STT_VAD_SILENCE_MS=700

# qwen-asr streaming config
STT_STREAMING_CHUNK_SIZE_SEC=2.0
STT_STREAMING_UNFIXED_CHUNK_NUM=2
STT_STREAMING_UNFIXED_TOKEN_NUM=5
